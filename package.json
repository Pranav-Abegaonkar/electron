{
  "name": "electron-example",
  "version": "0.1.0",
  "private": true,
  "homepage": ".",
  "main": "electron.js",
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "@heroicons/react": "^2.2.0",
    "@popperjs/core": "^2.11.8",
    "@videosdk.live/react-sdk": "^0.8.2",
    "fabric": "^5.5.2",
    "lottie-react": "^2.4.1",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-loader": "^8.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-player": "^2.16.0",
    "react-responsive": "^10.0.1",
    "react-scripts": "5.0.1",
    "react-toastify": "^11.0.5",
    "web-vitals": "^4.2.4"
  },
  "overrides": {
    "nth-check": "2.1.1",
    "postcss": "^8.4.31"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.16",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "wait-on": "^8.0.5"
  },
  "scripts": {
    "start": "react-scripts start",
    "electron": "electron .",
    "debug": "electron --inspect=5858 .",
    "debug-brk": "electron --inspect-brk=5858 .",
    "dev": "concurrently \"npm start\" \"wait-on http://localhost:3000 && electron .\"",
    "build": "react-scripts build",
    "build-electron": "npm run build && electron-builder --mac --publish never",
    "build-win": "npm run build && electron-builder --win --publish never",
    "build-all": "npm run build && electron-builder --mac --win --publish never",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "build": {
    "appId": "com.tyho.app",
    "productName": "TYHO",
    "extends": null,
    "npmRebuild": false,
    "asar": true,
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "files": [
      "build/**/*",
      "electron.js",
      "!node_modules/**/*",
      "!**/.DS_Store",
      "!**/*.map"
    ],
    "extraResources": [],
    "mac": {
      "category": "public.app-category.video",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "extendInfo": {
        "NSCameraUsageDescription": "This app requires camera access for video calls.",
        "NSMicrophoneUsageDescription": "This app requires microphone access for audio calls.",
        "NSScreenCaptureUsageDescription": "This app requires screen recording access for screen sharing."
      },
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ]
    },
    "dmg": {
      "title": "${productName} ${version}",
      "contents": [
        { "x": 130, "y": 220, "type": "file" },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ],
      "window": { "width": 540, "height": 380 }
    },
    "win": {
      "requestedExecutionLevel": "requireAdministrator",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TYHO",
      "uninstallDisplayName": "TYHO",
      "deleteAppDataOnUninstall": true,
      "perMachine": true,
      "installerLanguages": ["en_US"],
      "language": "1033",
      "runAfterFinish": false,
      "include": "installer.nsh"
    }
  }
}